# Database (Railway provides this automatically when you add PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/travel_booking?schema=public"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Travelpayouts API (sign up at travelpayouts.com)
TRAVELPAYOUTS_TOKEN=""
TRAVELPAYOUTS_MARKER=""

# Amadeus API (sign up at developers.amadeus.com)
AMADEUS_API_KEY=""
AMADEUS_API_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="SkyVoyager"
